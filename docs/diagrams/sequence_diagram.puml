@startuml sequence_diagram
actor User
participant "API Gateway\n(Chi Router)" as API
participant "AuditHandler" as Handler
participant "AuditService" as Service
participant "AuditRepository" as Repo
database "SQLite/SQL"

User -> API: POST /logs/audit-update
API -> Handler: DemoAuditUpdate()
Handler -> Service: Record(AuditEvent)
Service -> Service: Validate action/status
Service -> Service: Sanitize old/new values
Service -> Repo: Insert(event)
Repo -> "SQLite/SQL": INSERT audit_events
"SQLite/SQL" --> Repo: OK
Repo --> Service: nil
Service --> Handler: nil
Handler --> API: 201 Created
API --> User: JSON response
@enduml
