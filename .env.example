APP_ENV=local
APP_PORT=8080

# Default: SQLite (no PostgreSQL required)
DB_DRIVER=sqlite
SQLITE_PATH=./data/logger.db

# PostgreSQL (set driver and connection fields)
# DB_DRIVER=postgres
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=loggerdb
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_SSLMODE=disable

DB_AUTO_MIGRATE=true
SERVICE_NAME=application-logging-audit-module
ENABLE_CONSOLE_LOGGING=true
ENABLE_DATABASE_LOGGING=true
LOG_LEVEL=INFO

# Admin authentication (demo defaults: admin / 12345678)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=12345678
ADMIN_API_KEY=super-secret-admin-key
JWT_SECRET=change-this-secret
JWT_EXPIRY_HOURS=24
CORS_ORIGINS=http://localhost:5173

# Swagger UI at /swagger/ (dev only; disabled by default)
ENABLE_SWAGGER_UI=false
